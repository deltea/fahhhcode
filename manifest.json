{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "name": "FAHHHH",
  "description": "Plays the FAHHHH sound effect when you fail a leetcode problem and other times.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_icon": "/images/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*", "https://bhs-cs.gigamonkeys.com/c/csa/coding/*"],
      "js": ["/scripts/content.js"]
    }
  ],
  "background": {
    "service_worker": "/scripts/background.js"
  },
  "permissions": ["offscreen"],
  "web_accessible_resources": [
    {
      "resources": ["/fahhh.mp3", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
